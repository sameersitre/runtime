{
  "name": "@flotrace/runtime",
  "version": "2.3.3",
  "description": "Runtime package for FloTrace - enables real-time render tracking in your React app",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./babel-plugin": {
      "types": "./babel-plugin.d.ts",
      "default": "./babel-plugin.js"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime.d.ts",
      "import": "./jsx-runtime.mjs",
      "require": "./jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-dev-runtime.d.ts",
      "import": "./jsx-dev-runtime.mjs",
      "require": "./jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist",
    "babel-plugin.js",
    "babel-plugin.d.ts",
    "jsx-runtime.js",
    "jsx-runtime.mjs",
    "jsx-runtime.d.ts",
    "jsx-dev-runtime.js",
    "jsx-dev-runtime.mjs",
    "jsx-dev-runtime.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run -w @flotrace/runtime-core build && npm run clean && npm run build && npm run typecheck",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "dependencies": {
    "@flotrace/runtime-core": "2.3.3"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "@types/react": ">=16.9.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "react",
    "devtools",
    "profiler",
    "render",
    "performance",
    "flotrace"
  ],
  "license": "MIT",
  "homepage": "https://flotrace.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/sameersitre/runtime.git"
  },
  "bugs": {
    "url": "https://github.com/sameersitre/runtime/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
